diff --git a/k8s/analysistemplate-pingpong.yaml b/k8s/analysistemplate-pingpong.yaml
new file mode 100644
index 0000000..a60b7b6
--- /dev/null
+++ b/k8s/analysistemplate-pingpong.yaml
@@ -0,0 +1,23 @@
+apiVersion: argoproj.io/v1alpha1
+kind: AnalysisTemplate
+metadata:
+  name: pingpong-cpu-analysis
+  namespace: exercises
+spec:
+  metrics:
+    - name: namespace-cpu-rate-sum
+      # Measure every 30s for 5 minutes (10 x 30s).
+      interval: 30s
+      count: 10
+      # Any single breach fails the analysis and reverts the update.
+      failureLimit: 0
+      # Hardcoded threshold in cores for the summed CPU usage rate of
+      # all containers in the namespace. Setting this too low will make
+      # the analysis fail and prevent the update from ever completing.
+      failureCondition: result[0] > 0.5
+      successCondition: result[0] <= 0.5
+      provider:
+        prometheus:
+          address: http://kube-prometheus-stack-prometheus.prometheus.svc.cluster.local:9090
+          query: |
+            sum(rate(container_cpu_usage_seconds_total{namespace="exercises", container!=""}[1m]))
